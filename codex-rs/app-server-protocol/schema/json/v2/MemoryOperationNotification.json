{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "MemoryOperationKind": {
      "enum": [
        "recall",
        "remember",
        "update",
        "drop",
        "lessons",
        "crystals",
        "crystallize",
        "auto_crystallize",
        "insights",
        "reflect",
        "actions",
        "action_create",
        "action_update",
        "missions",
        "handoffs",
        "handoff_generate",
        "branch_overlays",
        "guardrails",
        "decisions",
        "dossiers",
        "routine_candidates",
        "frontier",
        "next"
      ],
      "type": "string"
    },
    "MemoryOperationScope": {
      "enum": [
        "none",
        "turn",
        "thread"
      ],
      "type": "string"
    },
    "MemoryOperationSource": {
      "enum": [
        "human",
        "assistant",
        "automatic"
      ],
      "type": "string"
    },
    "MemoryOperationStatus": {
      "enum": [
        "pending",
        "ready",
        "empty",
        "skipped",
        "error"
      ],
      "type": "string"
    }
  },
  "properties": {
    "contextInjected": {
      "type": "boolean"
    },
    "detail": {
      "type": [
        "string",
        "null"
      ]
    },
    "operation": {
      "$ref": "#/definitions/MemoryOperationKind"
    },
    "query": {
      "type": [
        "string",
        "null"
      ]
    },
    "scope": {
      "allOf": [
        {
          "$ref": "#/definitions/MemoryOperationScope"
        }
      ],
      "default": "none"
    },
    "source": {
      "$ref": "#/definitions/MemoryOperationSource"
    },
    "status": {
      "$ref": "#/definitions/MemoryOperationStatus"
    },
    "summary": {
      "type": "string"
    },
    "threadId": {
      "type": "string"
    }
  },
  "required": [
    "contextInjected",
    "operation",
    "source",
    "status",
    "summary",
    "threadId"
  ],
  "title": "MemoryOperationNotification",
  "type": "object"
}